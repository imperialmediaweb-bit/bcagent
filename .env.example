# Secret folosit pentru semnarea tokenurilor de acces ale agenților (HMAC-SHA256).
# Schimbă-l cu o valoare random lungă (>= 32 caractere).
TOKEN_SECRET=change-me-to-a-long-random-string

# Secret pentru endpoint-ul de emitere tokenuri (/api/issue-token).
ADMIN_SECRET=change-me-too

# Anthropic Claude API key pentru insights AI și chat.
# Obții cheia de pe https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override-uiete modelul Claude (default claude-opus-4-7).
# Opțiuni mai economice: claude-sonnet-4-6, claude-haiku-4-5
# ANTHROPIC_MODEL=claude-sonnet-4-6
