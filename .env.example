# === Auth tokens (semnătură HMAC pentru link-uri magice) ===
TOKEN_SECRET=change-me-to-a-long-random-string
ADMIN_SECRET=change-me-too

# === Persistență (Postgres opțional) ===
# Pe Railway: Add service → Database → Postgres. DATABASE_URL e injectat automat.
# Fără DATABASE_URL → fallback la localStorage (datele rămân doar pe device).
# DATABASE_URL=postgres://user:pass@host:5432/db

# === AI Provider ===
# Auto-detect: dacă OPENAI_API_KEY e setat → OpenAI; altfel ANTHROPIC.
# Override explicit cu AI_PROVIDER=openai sau AI_PROVIDER=anthropic.
# AI_PROVIDER=openai

# --- OpenAI ---
OPENAI_API_KEY=sk-...
# Optional: model OpenAI (default gpt-4o).
# Opțiuni: gpt-4o, gpt-4o-mini (mai ieftin), gpt-4.1, o3-mini, etc.
# OPENAI_MODEL=gpt-4o

# --- Anthropic Claude ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-7

# --- Google Gemini (în viitor) ---
# GEMINI_API_KEY=...
# GEMINI_MODEL=gemini-2.0-flash
